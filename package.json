{
  "name": "verifactu-oss",
  "private": true,
  "packageManager": "bun@1.2.9",
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "api:dev": "bun run --cwd \"$PWD/apps/api\" dev",
    "docs:dev": "bun run --cwd \"$PWD/apps/docs\" dev",
    "example:basic-sdk:dev": "bun run --cwd \"$PWD/examples/basic-sdk\" dev",
    "example:api-client:dev": "bun run --cwd \"$PWD/examples/api-client\" dev",
    "example:full-integration:dev": "bun run --cwd \"$PWD/examples/full-integration\" dev",
    "build": "turbo run build",
    "core:build": "bun run --cwd \"$PWD/packages/core\" build",
    "api:build": "bun run --cwd \"$PWD/apps/api\" build",
    "docs:build": "bun run --cwd \"$PWD/apps/docs\" build",
    "example:basic-sdk:build": "bun run --cwd \"$PWD/examples/basic-sdk\" build",
    "example:api-client:build": "bun run --cwd \"$PWD/examples/api-client\" build",
    "example:full-integration:build": "bun run --cwd \"$PWD/examples/full-integration\" build",
    "test": "turbo run test",
    "core:test": "bun run --cwd \"$PWD/packages/core\" test",
    "api:test": "bun run --cwd \"$PWD/apps/api\" test",
    "docs:test": "bun run --cwd \"$PWD/apps/docs\" test",
    "example:basic-sdk:test": "bun run --cwd \"$PWD/examples/basic-sdk\" test",
    "example:api-client:test": "bun run --cwd \"$PWD/examples/api-client\" test",
    "example:full-integration:test": "bun run --cwd \"$PWD/examples/full-integration\" test",
    "typecheck": "turbo run typecheck",
    "core:typecheck": "bun run --cwd \"$PWD/packages/core\" typecheck",
    "api:typecheck": "bun run --cwd \"$PWD/apps/api\" typecheck",
    "docs:typecheck": "bun run --cwd \"$PWD/apps/docs\" typecheck",
    "example:basic-sdk:typecheck": "bun run --cwd \"$PWD/examples/basic-sdk\" typecheck",
    "example:api-client:typecheck": "bun run --cwd \"$PWD/examples/api-client\" typecheck",
    "example:full-integration:typecheck": "bun run --cwd \"$PWD/examples/full-integration\" typecheck",
    "lint": "turbo run lint",
    "core:lint": "bun run --cwd \"$PWD/packages/core\" lint",
    "api:lint": "bun run --cwd \"$PWD/apps/api\" lint",
    "docs:lint": "bun run --cwd \"$PWD/apps/docs\" lint",
    "example:basic-sdk:lint": "bun run --cwd \"$PWD/examples/basic-sdk\" lint",
    "example:api-client:lint": "bun run --cwd \"$PWD/examples/api-client\" lint",
    "example:full-integration:lint": "bun run --cwd \"$PWD/examples/full-integration\" lint",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:ci": "biome check . && turbo run typecheck test build",
    "ci": "bun run check:ci",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@changesets/cli": "^2.29.7",
    "@types/qrcode": "^1.5.5",
    "bun-types": "^1.3.1",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  }
}
